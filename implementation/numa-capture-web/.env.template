# NUMA Capture Web — Environment Configuration
# Copy to .env or set in environment before running

# LLM configuration (for real interview orchestration)
# If unset, falls back to template prompts. Also reads DEEPSEEK_API_KEY.
NUMA_LLM_URL=https://api.deepseek.com/v1/chat/completions
NUMA_LLM_KEY=
NUMA_LLM_MODEL=deepseek-chat

# Server configuration
NUMA_HOST=0.0.0.0
NUMA_PORT=8765

# API Security — set a key to require X-API-Key header on all non-public endpoints
# Leave empty for dev mode (no auth)
NUMA_API_KEY=

# CORS — comma-separated origins, or * for any
NUMA_CORS_ORIGINS=*

# RAG server integration (for auto-indexing knowledge items)
# Set to false to disable
NUMA_RAG_URL=http://localhost:9191
NUMA_RAG_ENABLED=true
